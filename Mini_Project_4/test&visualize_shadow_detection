import numpy as np
from PIL import Image

from shadow_detection import sector, find_sector_corners, generate_rays
from shadow_detection import ray_intensity_profiles, shadow_segments, ray_shadow_mask
from shadow_detection import filter_standalone_shadow_rays, smooth_and_fill_shadow_mask, extract_largest_shadows

dicom_array = np.load("dicom_arrays/starting_US_test_c(577, 649, 850).npy")
transducer_used = "curvilinear"

avg = np.average(dicom_array)

overlay_frames = []
for frame_num in range(len(dicom_array)): # length of dicom_array is num scans
    frame_image = dicom_array[frame_num]

    ### Shadow detection ###

    # Generate radial rays
    sector_mask = sector(frame_image)
    corners = find_sector_corners(sector_mask, transducer_used = transducer_used)

    points_per_ray = 100
    rays = generate_rays(corners, num_rays=200, points_per_ray = points_per_ray, transducer_used = transducer_used)

    # Shadow detection along ray profiles
    profiles = ray_intensity_profiles(frame_image, rays)

    # Dark shadows
    all_rays_shadow_segments = shadow_segments(profiles, shadow_threshold=avg, min_shadow_length=points_per_ray/10, shadow_min_threshold = 0)
    
    # Medium, long shadows
    #all_rays_shadow_segments = shadow_segments(profiles, shadow_threshold=avg*3, min_shadow_length=points_per_ray/3, shadow_min_threshold = avg)

    # Posterior acoustic enhancement
    #all_rays_shadow_segments = shadow_segments(profiles, shadow_threshold=255, min_shadow_length=points_per_ray/10, shadow_min_threshold = avg*4.5)

    ray_shadows = ray_shadow_mask(rays, all_rays_shadow_segments, frame_image.shape)

    # Final smooth shadow mask
    filtered_shadow_mask = filter_standalone_shadow_rays(ray_shadows, rays, all_rays_shadow_segments, neighbor_range=1)
    filled_shadow_mask = smooth_and_fill_shadow_mask(filtered_shadow_mask, dilation_iter=5, closing_iter=3)
    final_shadow_mask = extract_largest_shadows(filled_shadow_mask, min_area=500)


    ### Overlaying shadow mask on scan ###
    
    # RGBA for frame image
    rgb_frame_image = np.stack([frame_image, frame_image, frame_image], axis=-1)  # (height, width, 3), RGB equal for US scan
    alpha_frame_image = np.full(frame_image.shape, 255, dtype=np.uint8) # fully opaque for US scan
    rgba_frame_image = np.concatenate([rgb_frame_image, alpha_frame_image[:, :, np.newaxis]], axis=-1)

    # Overlay red tint where shadow is detected
    mask = final_shadow_mask.astype(bool)
    tint_strength = 0.25  # 0 to 1 (1 is full red)

    # red channel
    rgba_frame_image[mask, 0] = np.clip((1 - tint_strength) * rgba_frame_image[mask, 0] + tint_strength * 255, 0, 255)
    # green channel
    rgba_frame_image[mask, 1] = rgba_frame_image[mask, 1] * (1 - tint_strength)
    # blue channel
    rgba_frame_image[mask, 2] = rgba_frame_image[mask, 2] * (1 - tint_strength)
    # alpha channel
    rgba_frame_image[mask, 3] = 255  # fully opaque

    overlay_frames.append(rgba_frame_image)

# stack into one array for visualization
overlay_array = np.stack(overlay_frames, axis=0)  # shape: (577, H, W, 4)




### Visualization

import matplotlib.pyplot as plt
from matplotlib.widgets import Slider

# Generate original grayscale RGB frames (for display only)
original_rgb_frames = np.stack([dicom_array] * 3, axis=-1).astype(np.uint8)  # shape (577, H, W, 3)

# Set up side-by-side display
fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(10, 5))
plt.subplots_adjust(bottom=0.2)

# Show original on left
img1 = ax1.imshow(original_rgb_frames[0], cmap='gray', interpolation='none')
ax1.set_title("Original")
ax1.axis('off')

# Show tinted overlay on right
img2 = ax2.imshow(overlay_array[0], interpolation='none')
ax2.set_title("Shadow Overlay")
ax2.axis('off')

# Add slider
ax_slider = plt.axes([0.2, 0.05, 0.6, 0.03])
slider = Slider(ax_slider, 'Frame', 0, overlay_array.shape[0] - 1, valinit=0, valstep=1)

# Update function for slider
def update(val):
    frame = int(slider.val)
    img1.set_data(original_rgb_frames[frame])
    img2.set_data(overlay_array[frame])
    fig.canvas.draw_idle()

slider.on_changed(update)
plt.show()
